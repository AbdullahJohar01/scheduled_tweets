<div class="container mt-4">
    <h2>Forgot Password</h2>
  
    <%= form_with url: password_resets_path, method: :post do |f| %>
      <div class="mb-3">
        <%= f.label :email, "Email", class: "form-label" %>
        <%= f.email_field :email, name: "email", class: "form-control", placeholder: "Enter your email" %>
      </div>
      <%= f.submit "Send Reset Link", class: "btn btn-primary" %>
    <% end %>
  </div>